# ============================================================
# Mordev POS — Variables de Entorno
# Copia este archivo a ".env" y rellena tus valores reales.
# NUNCA subas el archivo .env a GitHub.
# ============================================================

# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://rrfkqqvdzslyufqxuome.supabase.co
# Usa la Service Role Key (Settings > API > service_role)
SUPABASE_KEY=tu_service_role_key_aqui

# Identificador único de esta instancia del POS
ID_USUARIO=mordev_pos_v1

# ── Mercado Pago ──────────────────────────────────────────
# Obtenla en: https://www.mercadopago.com.co/developers/panel
MERCADO_PAGO_ACCESS_TOKEN=tu_access_token_aqui

# URL pública de tu servidor (para el webhook de Mercado Pago)
# Ejemplo Render: https://mordev-pos.onrender.com
APP_BASE_URL=https://tu-dominio.onrender.com

# ── Flask ─────────────────────────────────────────────────
# Cambia esto por una cadena aleatoria segura en producción
FLASK_SECRET_KEY=mordev-pos-secret-2026-cambia-esto
